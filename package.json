{
  "name": "cf-ai-site-starter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.6.0",
  "scripts": {
    "dev": "concurrently -n frontend,worker -c cyan,green \"npm run dev -w app/frontend\" \"npm run dev -w app/worker\"",
    "build": "npm run build -w app/frontend && npm run build -w app/worker",
    "lint": "eslint .",
    "typecheck": "npm run typecheck -w app/frontend && npm run typecheck -w app/worker",
    "test": "vitest run",
    "cf:types": "wrangler types app/worker/src/worker-configuration.d.ts",
    "cf:deploy": "wrangler deploy",
    "cf:migrate:local": "wrangler d1 migrations apply cf_ai_site_db --local",
    "cf:migrate:remote": "wrangler d1 migrations apply cf_ai_site_db --remote"
  },
  "workspaces": [
    "app/frontend",
    "app/worker"
  ],
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.68",
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.17",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3",
    "wrangler": "^4.14.4"
  }
}
